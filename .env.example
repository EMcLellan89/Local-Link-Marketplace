# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Development Mode (DISABLE BEFORE GOING LIVE!)
# Set to 'true' to bypass authentication for development
VITE_DEV_MODE=false

# Bypass Mode (TESTING & DEMO MODE - DISABLE BEFORE GOING LIVE!)
# Set to 'true' to bypass ALL passwords and payments
# Perfect for testing, demos, and navigating the platform freely
# When enabled:
#   ✅ No login required - instant access to all dashboards
#   ✅ No payment required - all purchases automatically succeed
#   ✅ Navigate and test everything without barriers
VITE_BYPASS_MODE=false

# Stripe Payment Integration (PAYMENT PROCESSOR FOR ENTIRE PLATFORM)
# Used for: Course purchases, deal purchases, subscriptions, all merchant services
# Get from: https://dashboard.stripe.com/apikeys
# Required to accept payments on the platform
STRIPE_SECRET_KEY=your_stripe_secret_key_here
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Error Monitoring (Optional but Recommended)
# Get your DSN from https://sentry.io
# Sentry will only initialize in production mode
VITE_SENTRY_DSN=your_sentry_dsn_here

# Email Service (Optional)
# Options: 'sendgrid', 'resend', 'console'
# Note: Only 'console' is currently implemented (logs to console in development)
VITE_EMAIL_PROVIDER=console

# Local-Link Integration (Sales/Accounting Attribution) - REQUIRED FOR PRODUCTION
# Sends all sales and accounting data to Local-Link platform for partner attribution
# Get credentials from Local-Link team or dashboard
VITE_LOCAL_LINK_BASE_URL=https://local-link.com
LOCAL_LINK_INGEST_URL=https://local-link.com/api/ingest/sale
LOCAL_LINK_INGEST_SECRET=your_local_link_secret_here
LOCAL_LINK_WEBHOOK_URL=https://local-link.com/api/webhooks/frontdesk-ai-pro
LOCAL_LINK_API_KEY=your_local_link_api_key_here
