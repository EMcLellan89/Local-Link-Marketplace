  "test_scenarios": {
    "scenario_1_new_referral": {
      "description": "Test complete affiliate flow from click to commission",
      "steps": [
        "1. User clicks referral link with code PARTNER123",
        "2. Record click in affiliate_clicks table",
        "3. User completes course purchase",
        "4. Webhook creates commission record",
        "5. Partner views pending commission in dashboard",
        "6. Admin approves commission",
        "7. Partner requests payout",
        "8. Admin processes payout"
      ]
    },
    "scenario_2_one_click_upsell": {
      "description": "Test upsell purchase after course completion",
      "steps": [
        "1. User completes AI Receptionist course purchase",
        "2. Webhook stores Stripe customer ID",
        "3. User sees upsell offers on success page",
        "4. User clicks 'Add to Order' on script pack",
        "5. Frontend calls one-click-upsell function",
        "6. Payment confirmed with saved card",
        "7. Webhook grants entitlement"
      ]
    },
    "scenario_3_contract_signing": {
      "description": "Test digital contract signature",
      "steps": [
        "1. Admin creates contract for partner",
        "2. Partner views contract in dashboard",
        "3. Partner clicks 'Sign Agreement'",
        "4. Partner enters legal name and accepts",
        "5. System records signature with IP",
        "6. Partner downloads signed PDF"
      ]
    }
  }
